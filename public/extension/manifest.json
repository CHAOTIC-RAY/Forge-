{
  "manifest_version": 3,
  "name": "Forge Web Clipper",
  "version": "1.0",
  "description": "Clip websites and add notes to your Forge notebook.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://forge.chaoticstudio.workers.dev/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://forge.chaoticstudio.workers.dev/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  }
}
