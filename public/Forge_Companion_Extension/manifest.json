{
  "manifest_version": 3,
  "name": "Forge Companion & AI",
  "version": "2.0",
  "description": "Clip websites, track your calendar, and chat with AI from anywhere.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://forge.chaoticstudio.workers.dev/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://forge.chaoticstudio.workers.dev/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  }
}
