{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A social media post scheduled in the calendar",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "outlet": { "type": "string" },
        "productCategory": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "brief": { "type": "string" },
        "caption": { "type": "string" },
        "hashtags": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" },
        "userId": { "type": "string", "description": "The UID of the user who owns this post" },
        "businessId": { "type": "string", "description": "The ID of the business this post belongs to" }
      },
      "required": ["id", "date", "outlet", "type", "title", "brief", "caption", "hashtags", "userId", "businessId"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "InventoryProduct": {
      "title": "InventoryProduct",
      "description": "A product in the main inventory database",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "link": { "type": "string" },
        "stockInfo": { "type": "string" },
        "outlet": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "businessId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "userId", "businessId"]
    },
    "CategoryCount": {
      "title": "CategoryCount",
      "description": "Product count per category",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "count": { "type": "integer" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "count", "userId"]
    },
    "Todo": {
      "title": "Todo",
      "description": "A task in the todo list",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "dueDate": { "type": "string", "format": "date" },
        "businessId": { "type": "string" }
      },
      "required": ["id", "text", "completed", "userId", "createdAt", "businessId"]
    },
    "Business": {
      "title": "Business",
      "description": "A business profile managed by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "description": { "type": "string" },
        "industry": { "type": "string" },
        "position": { "type": "string" },
        "brandColors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "accent": { "type": "string" }
          }
        },
        "logoUrl": { "type": "string" },
        "shareToken": { "type": "string" },
        "shareRestriction": { "type": "string", "enum": ["guest", "authenticated"] },
        "sharePassword": { "type": "string" },
        "shareExpiresAt": { "type": "string", "format": "date-time" },
        "shareFilters": {
          "type": "object",
          "properties": {
            "tags": { "type": "array", "items": { "type": "string" } },
            "dateRange": {
              "type": "object",
              "properties": {
                "start": { "type": "string", "format": "date" },
                "end": { "type": "string", "format": "date" }
              }
            }
          }
        },
        "shareAnalytics": {
          "type": "object",
          "properties": {
            "views": { "type": "integer" },
            "lastViewedAt": { "type": "string", "format": "date-time" }
          }
        },
        "themePreset": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "members": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "ownerId", "createdAt", "updatedAt"]
    },
    "ShortLink": {
      "title": "ShortLink",
      "description": "A shortened URL for campaigns",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "originalUrl": { "type": "string" },
        "shortCode": { "type": "string" },
        "businessId": { "type": "string" },
        "clicks": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "originalUrl", "shortCode", "businessId", "clicks", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment left on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "userName", "text", "createdAt"]
    },
    "IdeaHistory": {
      "title": "IdeaHistory",
      "description": "A saved AI generated idea",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "title": { "type": "string" },
        "brief": { "type": "string" },
        "caption": { "type": "string" },
        "hashtags": { "type": "string" },
        "type": { "type": "string" },
        "outlet": { "type": "string" },
        "format": { "type": "string" },
        "feasibility": { "type": "number" },
        "impact": { "type": "number" }
      },
      "required": ["id", "businessId"]
    },
    "Notebook": {
      "title": "Notebook",
      "description": "An infinite canvas notebook for visual strategy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "image", "prompt", "graph"] },
              "content": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "color": { "type": "string" }
            }
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "businessId", "userId", "blocks", "links"]
    }
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "User's business profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of scheduled posts"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on posts"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/inventory_products/{productId}": {
      "schema": "InventoryProduct",
      "description": "User's main inventory database"
    },
    "/inventory_category_counts/{countId}": {
      "schema": "CategoryCount",
      "description": "User's inventory category counts"
    },
    "/todos/{todoId}": {
      "schema": "Todo",
      "description": "User's todo list items"
    },
    "/idea_history/{historyId}": {
      "schema": "IdeaHistory",
      "description": "Saved AI ideas"
    },
    "/brand_kits/{businessId}": {
      "schema": "Business",
      "description": "Brand kit settings for a business"
    },
    "/categories/{businessId}": {
      "schema": "Business",
      "description": "Category settings for a business"
    },
    "/notebooks/{notebookId}": {
      "schema": "Notebook",
      "description": "User's infinite canvas notebooks"
    },
    "/short_links/{shortCode}": {
      "schema": "ShortLink",
      "description": "Shortened URLs for redirection"
    }
  }
}
