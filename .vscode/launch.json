{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Dev Server + Edge Debug",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "(?:\\[Server\\] Server running on http://localhost:|Local:\\s+http://localhost:|url: http://localhost:)(\\d+)",
                "uriFormat": "http://localhost:%s",
                "action": "debugWithEdge"
            },
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "name": "Node.js: Attach to Process",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Edge: Attach to localhost",
            "type": "msedge",
            "request": "attach",
            "port": 9222,
            "urlFilter": "http://localhost:3000/*",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "skipFiles": [
                "**/node_modules/**"
            ]
        },
        {
            "request": "launch",
            "name": "Launch Edge",
            "type": "msedge",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ]
        }
    ]
}