# Supabase auth bridge (required for Firebase login → Supabase RLS)
# Get JWT Secret: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
# Service role: Supabase Dashboard → API → service_role secret
# Supports legacy JWT keys (eyJ...) or new sb_secret_... keys
# Either name works on the Worker:
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=
FIREBASE_PROJECT_ID=gen-lang-client-0018612871
VITE_SUPABASE_URL=https://tpjiowcovqfvmuockpop.supabase.co

# --- Production (Cloudflare Worker) ---
# Do NOT commit real values. Set encrypted secrets in:
# Cloudflare Dashboard → Workers → forge → Settings → Variables and Secrets
# Or: npx wrangler secret put SUPABASE_JWT_SECRET
#     npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY
