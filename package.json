{
  "name": "forge",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --outfile=dist/server.js --external:vite --external:express --external:axios",
    "start": "node dist/server.js",
    "preview": "npm run build && wrangler dev",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.29.0",
    "@heyputer/puter.js": "^2.2.15",
    "@splinetool/react-spline": "^4.1.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/d3": "^7.4.3",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^11.10.0",
    "glob": "^13.0.6",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-firebase-hooks": "^5.1.1",
    "react-router-dom": "^7.13.2",
    "react-zoom-pan-pinch": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "wrangler": "^4.81.1",
    "xlsx": "^0.18.5"
  }
